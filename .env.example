PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/consora
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
UPLOAD_DIR=uploads

# Public base URL used inside verification / reset-password email links.
# For local dev with a phone: use your machine's LAN IP, e.g. http://192.168.1.20:3000
# In production: use your HTTPS origin, e.g. https://api.consora.app
PUBLIC_BASE_URL=http://localhost:3000

# Deep-link scheme for the Flutter app. Keep this in sync with the native
# config (AndroidManifest intent-filter + iOS Info.plist URL scheme).
APP_DEEP_LINK_SCHEME=consora

# --- Creator feature gate ---
# Minimum trust score (0-100) required to unlock challenge creation.
# At this score a user auto-promotes to 'creator'; dropping below
# demotes them back to 'user'. Admins bypass this entirely.
CREATOR_TRUST_THRESHOLD=100

# --- Admin seed (used by `npm run seed`) ---
ADMIN_EMAIL=admin@consora.com
ADMIN_PASSWORD=admin12345
ADMIN_FIRST_NAME=Consora
ADMIN_LAST_NAME=Admin

# --- Email / SMTP ---
# See email-settings.md for step-by-step provider setup (Gmail, SendGrid,
# Mailgun, Postmark, Resend SMTP, etc). If these are empty, emails are
# logged to stdout so local dev still works without a real mailbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Consora <no-reply@consora.app>

# --- Google Sign-In ---
# See google-social.md. At least one of these must be set to enable
# POST /auth/google. When you have both an iOS client and an Android/Web
# client, list the Web one here and the others in their dedicated vars —
# the server accepts tokens minted for any of them.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=

# --- Apple Sign-In ---
# See apple-social.md. This is your Services ID (for web/Android) or the
# app bundle id (for native iOS sign_in_with_apple). Set to enable
# POST /auth/apple.
APPLE_CLIENT_ID=

PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/consora
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3000

# --- Creator feature gate ---
# Minimum trust score (0-100) required to unlock challenge creation
CREATOR_TRUST_THRESHOLD=75

# --- Admin seed (used by `npm run seed`) ---
ADMIN_EMAIL=admin@consora.com
ADMIN_PASSWORD=admin12345
ADMIN_FIRST_NAME=Consora
ADMIN_LAST_NAME=Admin
